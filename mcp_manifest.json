{
  "schema_version": "v1",
  "name_for_model": "FundInfoPro",
  "name_for_human": "中国基金信息查询 Pro",
  "description_for_model": "专业的中国公募基金数据查询工具，基于 akshare 实现。主要功能：\n\n1. 基金搜索：支持按基金代码、名称、拼音缩写搜索\n2. 详细查询：获取基金的完整信息，包括净值、业绩、持仓、风险指标等\n3. 排行榜查询：获取各类型基金的业绩排行榜\n4. 评级查询：获取上海证券、招商证券、济安金信等机构的评级\n\n数据来源于东方财富天天基金，实时更新。",
  "description_for_human": "提供中国公募基金的实时数据查询服务，包括净值查询、历史业绩、持仓分析、风险评估、基金评级等功能。基于 akshare 和 FastAPI 构建。",
  "auth": {
    "type": "none"
  },
  "api": {
    "type": "openapi",
    "url": "http://127.0.0.1:8000/openapi.json"
  },
  "logo_url": "https://akshare.akfamily.xyz/logo.png",
  "contact_email": "noreply@example.com",
  "legal_info_url": "",
  "capabilities": {
    "tools": [
      {
        "name": "search_funds",
        "description": "搜索基金，支持按代码、名称、拼音缩写查询",
        "input_schema": {
          "type": "object",
          "properties": {
            "keyword": {
              "type": "string",
              "description": "搜索关键词，可以是基金代码、基金名称或拼音缩写"
            },
            "limit": {
              "type": "integer",
              "description": "返回结果数量限制，默认50",
              "default": 50
            }
          },
          "required": ["keyword"]
        }
      },
      {
        "name": "get_fund_details",
        "description": "获取基金详细信息，包括净值、业绩、持仓、风险指标等",
        "input_schema": {
          "type": "object",
          "properties": {
            "code": {
              "type": "string",
              "description": "6位基金代码"
            }
          },
          "required": ["code"]
        }
      },
      {
        "name": "get_fund_rankings",
        "description": "获取基金业绩排行榜",
        "input_schema": {
          "type": "object",
          "properties": {
            "fund_type": {
              "type": "string",
              "description": "基金类型：全部、股票型、混合型、债券型、指数型、QDII、FOF",
              "enum": ["全部", "股票型", "混合型", "债券型", "指数型", "QDII", "FOF"],
              "default": "全部"
            },
            "limit": {
              "type": "integer",
              "description": "返回结果数量限制，默认100",
              "default": 100
            }
          },
          "required": []
        }
      },
      {
        "name": "get_fund_rating",
        "description": "获取基金评级信息（上海证券、招商证券、济安金信等）",
        "input_schema": {
          "type": "object",
          "properties": {
            "code": {
              "type": "string",
              "description": "基金代码"
            }
          },
          "required": ["code"]
        }
      },
      {
        "name": "refresh_cache",
        "description": "刷新基金数据缓存",
        "input_schema": {
          "type": "object",
          "properties": {},
          "required": []
        }
      }
    ]
  }
}
